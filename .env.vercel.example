# Vercel environment template
#
# If the Vercel Neon integration already injected DATABASE_URL, do not import
# an old local DATABASE_URL over it. Only uncomment this line when you need to
# paste the Neon pooled connection string manually.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://your-project.vercel.app"

# Configure one AI provider to start. The app will use whichever provider has
# a valid API key.

# DeepSeek
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_API_KEY="your-deepseek-key"
DEEPSEEK_MODEL="deepseek-chat"

# OpenAI
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_API_KEY="your-openai-key"
# OPENAI_MODEL="gpt-4o-mini"

# MiMo
# MIMO_BASE_URL="https://api.siliconflow.cn/v1"
# MIMO_API_KEY="your-mimo-key"
# MIMO_MODEL="MiMo-7B-Chat"
